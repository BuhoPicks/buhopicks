// BH Analysis — Tennis Analytics Platform Schema
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── User & Authentication ───────────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String    // Hashed
  role          String    @default("USER") // USER, ADMIN
  
  subscription  Subscription?
  preferences   UserPreferences?
  
  lastLogin     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Subscription {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  plan            String    @default("FREE") // FREE, PREMIUM, VIP
  status          String    @default("ACTIVE") // ACTIVE, EXPIRED, CANCELLED
  
  startDate       DateTime  @default(now())
  endDate         DateTime? // Null for lifetime or auto-renew
  
  stripeCustomerId String?  @unique
  stripePriceId   String?
  
  updatedAt       DateTime  @updatedAt
  createdAt       DateTime  @default(now())
}


// ─── Tennis Match ─────────────────────────────────────────────────────────────
model TennisMatch {
  id             String   @id @default(cuid())
  espnId         String?  @unique
  
  // Players
  player1Name    String
  player2Name    String
  player1Ranking Int?     // ATP/WTA ranking
  player2Ranking Int?
  player1Country String?
  player2Country String?
  
  // Tournament Info
  tournament     String
  tournamentId   String?
  circuit        String   @default("ATP")   // ATP, WTA, Challenger, ITF
  round          String?                     // R128, R64, R32, R16, QF, SF, F
  surface        String   @default("Hard")  // Hard, Clay, Grass, Carpet
  tournamentLevel String  @default("250")   // GS, Masters, 500, 250, Challenger, ITF
  city           String?
  country        String?
  indoor         Boolean  @default(false)
  
  // Schedule
  date           DateTime
  status         String   @default("SCHEDULED") // SCHEDULED, LIVE, FINISHED, CANCELLED, DELAYED
  
  // Result (filled after match)
  result         String?  // e.g. "Player1 6-4 6-3"
  winnerId       String?  // "player1" or "player2"
  score          String?
  sets           Int?     // number of sets played
  totalGames     Int?     // total games played
  duration       Int?     // minutes
  
  // Metadata
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  picks          TennisPick[]
  syncLogId      String?
}

// ─── Tennis Pick ──────────────────────────────────────────────────────────────
model TennisPick {
  id              String   @id @default(cuid())
  matchId         String
  match           TennisMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  
  // Pick Definition
  market          String   // MATCH_WINNER, GAMES_OVER_UNDER, GAMES_HANDICAP, SET_WINNER, TOTAL_SETS, FIRST_SET_WINNER
  selection       String   // e.g. "Player1", "Over 21.5", "Player1 -3.5", "2 Sets"
  description     String   // Human readable: "Djokovic ganador del partido"
  
  // Odds & Value
  odds            Float    // Cuota estimada de mercado
  trueOdds        Float    // Cuota justa según modelo
  estimatedProb   Float    // Probabilidad estimada 0-1
  expectedValue   Float    // EV = prob * odds - 1 (e.g. 0.08 = 8% value)
  
  // Confidence
  confidenceScore Int      // 0-100
  valueLabel      String   @default("MEDIUM") // LOW, MEDIUM, HIGH, PREMIUM
  isPremiumPick   Boolean  @default(false)  // Best pick of the day
  
  // Analysis
  explanation     String   // Brief explanation
  statsBreakdown  String?  // JSON with detailed stat breakdown
  
  // Result
  status          String   @default("PENDING")  // PENDING, WON, LOST, VOID, CANCELLED
  settledAt       DateTime?
  
  // History
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  historyEntry    PickHistory?
}

// ─── Pick History (tracking results) ─────────────────────────────────────────
model PickHistory {
  id              String   @id @default(cuid())
  pickId          String   @unique
  pick            TennisPick @relation(fields: [pickId], references: [id], onDelete: Cascade)
  
  result          String   // WON, LOST, VOID
  odds            Float    // Odds at time of bet
  stake           Float    @default(1.0)   // Units staked
  profit          Float    // Profit/loss in units
  
  notes           String?
  settledAt       DateTime @default(now())
}

// ─── Player Stats Cache ────────────────────────────────────────────────────────
model PlayerStats {
  id              String   @id @default(cuid())
  playerName      String   @unique
  circuit         String   @default("ATP")
  
  // Rankings
  currentRanking  Int?
  peakRanking     Int?
  rankingPoints   Int?
  
  // Career
  winRate         Float?   // career win rate 0-1
  surfaceWinRates String?  // JSON: {hard: 0.65, clay: 0.72, grass: 0.60}
  
  // Recent form (last 5 and 10 matches)
  form5           String?  // "WWLWW"
  form10          String?  // "WWLWWLWWLW"
  formScore       Float?   // Calculated score
  
  // Service stats
  firstServePerc  Float?   // e.g. 0.65
  firstServeWon   Float?   // e.g. 0.78
  secondServeWon  Float?   // e.g. 0.55
  acesPer100      Float?   // aces per 100 service points
  dfPer100        Float?   // double faults per 100 service points
  
  // Return stats
  returnWon       Float?   // return points won
  
  // Break points
  bpConverted     Float?   // 0-1
  bpSaved         Float?   // 0-1
  
  // Surface specialists
  isClayCourt     Boolean  @default(false)
  isGrassCourt    Boolean  @default(false)
  isHardCourt     Boolean  @default(false)
  
  // Tournament performance
  grandSlamWinRate Float?
  masters1000Rate  Float?
  
  // Physical
  isInjured       Boolean  @default(false)
  injuryNote      String?
  daysLastMatch   Int?     // Days since last match (fatigue)
  
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())
}

// ─── Head to Head Cache ───────────────────────────────────────────────────────
model H2HRecord {
  id              String   @id @default(cuid())
  player1Name     String
  player2Name     String
  
  totalMatches    Int      @default(0)
  player1Wins     Int      @default(0)
  player2Wins     Int      @default(0)
  
  // Surface specific
  hardWinsP1      Int      @default(0)
  hardWinsP2      Int      @default(0)
  clayWinsP1      Int      @default(0)
  clayWinsP2      Int      @default(0)
  grassWinsP1     Int      @default(0)
  grassWinsP2     Int      @default(0)
  
  lastMatchDate   DateTime?
  lastMatchResult String?
  
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())
  
  @@unique([player1Name, player2Name])
}

// ─── Football Match ───────────────────────────────────────────────────────────
model FootballMatch {
  id             String   @id @default(cuid())
  espnId         String?  @unique
  
  homeTeam       String
  awayTeam       String
  homeLogo       String?
  awayLogo       String?
  
  league         String
  leagueLogo     String?
  date           DateTime
  status         String   @default("SCHEDULED")
  
  homeScore      Int?
  awayScore      Int?
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  picks          FootballPick[]
}

// ─── Football Pick ────────────────────────────────────────────────────────────
model FootballPick {
  id              String   @id @default(cuid())
  matchId         String
  match           FootballMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  
  market          String   // 1X2, OVER_UNDER, BTTS, HANDICAP
  selection       String   // "Home", "X", "Away", "Over 2.5", etc.
  description     String
  
  odds            Float
  trueOdds        Float
  estimatedProb   Float
  expectedValue   Float
  
  confidenceScore Int
  valueLabel      String   @default("MEDIUM")
  isPremiumPick   Boolean  @default(false)
  
  explanation     String
  status          String   @default("PENDING")
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── Daily Sync Log ────────────────────────────────────────────────────────────
model DailySyncLog {
  id              String   @id @default(cuid())
  syncedAt        DateTime @default(now())
  status          String   // SUCCESS, PARTIAL, FAILED
  sport           String   @default("TENNIS") // TENNIS, FOOTBALL
  matchesFound    Int      @default(0)
  picksGenerated  Int      @default(0)
  premiumPicks    Int      @default(0)
  circuits        String?  // JSON array of circuits/leagues synced
  errorMessage    String?
  durationMs      Int?
}

// ─── User Preferences ─────────────────────────────────────────────────────────
model UserPreferences {
  id              String   @id @default(cuid())
  
  // Sport toggles
  showTennis      Boolean  @default(true)
  showFootball    Boolean  @default(true)

  // Circuit filters
  showATP         Boolean  @default(true)
  showWTA         Boolean  @default(true)
  showChallenger  Boolean  @default(true)
  showITF         Boolean  @default(false)
  
  // Risk profile
  riskProfile     String   @default("BALANCED") // CONSERVATIVE, BALANCED, AGGRESSIVE
  minConfidence   Int      @default(60)
  minOdds         Float    @default(1.50)
  maxOdds         Float    @default(5.00)
  minEV           Float    @default(0.03)
  
  // Notifications
  emailAlerts     Boolean  @default(false)
  telegramAlerts  Boolean  @default(false)
  pushAlerts      Boolean  @default(false)
  alertEmail      String?
  alertTelegram   String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
