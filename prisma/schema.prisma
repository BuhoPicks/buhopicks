generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── User & Authentication ───────────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String    // Hashed
  role          String    @default("USER") // USER, ADMIN
  
  subscription  Subscription?
  preferences   UserPreferences?
  
  lastLogin     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Subscription {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  plan            String    @default("FREE") // FREE, MONTHLY, QUARTERLY, SEMIANNUAL, ANNUAL
  status          String    @default("INACTIVE") // ACTIVE, INACTIVE, PAST_DUE, CANCELLED
  
  startDate       DateTime  @default(now())
  endDate         DateTime?
  
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  stripePriceId        String?
  
  updatedAt       DateTime  @updatedAt
  createdAt       DateTime  @default(now())
}

// ─── Tennis Match ─────────────────────────────────────────────────────────────
model TennisMatch {
  id             String   @id @default(cuid())
  espnId         String?  @unique
  
  player1Name    String
  player2Name    String
  player1Ranking Int?
  player2Ranking Int?
  player1Country String?
  player2Country String?
  
  tournament     String
  tournamentId   String?
  circuit        String   @default("ATP")
  round          String?
  surface        String   @default("Hard")
  tournamentLevel String  @default("250")
  city           String?
  country        String?
  indoor         Boolean  @default(false)
  
  date           DateTime
  status         String   @default("SCHEDULED")
  
  result         String?
  winnerId       String?
  score          String?
  sets           Int?
  totalGames     Int?
  duration       Int?
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  picks          TennisPick[]
  syncLogId      String?
}

model TennisPick {
  id              String   @id @default(cuid())
  matchId         String
  match           TennisMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  
  market          String
  selection       String
  description     String
  
  odds            Float
  trueOdds        Float
  estimatedProb   Float
  expectedValue   Float
  
  confidenceScore Int
  valueLabel      String   @default("MEDIUM")
  isPremiumPick   Boolean  @default(false)
  
  explanation     String
  statsBreakdown  String?
  
  status          String   @default("PENDING")
  settledAt       DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  historyEntry    PickHistory?
}

model PickHistory {
  id              String   @id @default(cuid())
  pickId          String   @unique
  pick            TennisPick @relation(fields: [pickId], references: [id], onDelete: Cascade)
  
  result          String
  odds            Float
  stake           Float    @default(1.0)
  profit          Float
  
  notes           String?
  settledAt       DateTime @default(now())
}

model PlayerStats {
  id              String   @id @default(cuid())
  playerName      String   @unique
  circuit         String   @default("ATP")
  
  currentRanking  Int?
  peakRanking     Int?
  rankingPoints   Int?
  
  winRate         Float?
  surfaceWinRates String?
  
  form5           String?
  form10          String?
  formScore       Float?
  
  firstServePerc  Float?
  firstServeWon   Float?
  secondServeWon  Float?
  acesPer100      Float?
  dfPer100        Float?
  
  returnWon       Float?
  
  bpConverted     Float?
  bpSaved         Float?
  
  isClayCourt     Boolean  @default(false)
  isGrassCourt    Boolean  @default(false)
  isHardCourt     Boolean  @default(false)
  
  grandSlamWinRate Float?
  masters1000Rate  Float?
  
  isInjured       Boolean  @default(false)
  injuryNote      String?
  daysLastMatch   Int?
  
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())
}

model H2HRecord {
  id              String   @id @default(cuid())
  player1Name     String
  player2Name     String
  
  totalMatches    Int      @default(0)
  player1Wins     Int      @default(0)
  player2Wins     Int      @default(0)
  
  hardWinsP1      Int      @default(0)
  hardWinsP2      Int      @default(0)
  clayWinsP1      Int      @default(0)
  clayWinsP2      Int      @default(0)
  grassWinsP1     Int      @default(0)
  grassWinsP2     Int      @default(0)
  
  lastMatchDate   DateTime?
  lastMatchResult String?
  
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())
  
  @@unique([player1Name, player2Name])
}

model FootballMatch {
  id             String   @id @default(cuid())
  espnId         String?  @unique
  
  homeTeam       String
  awayTeam       String
  homeLogo       String?
  awayLogo       String?
  
  league         String
  leagueLogo     String?
  date           DateTime
  status         String   @default("SCHEDULED")
  
  homeScore      Int?
  awayScore      Int?
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  picks          FootballPick[]
}

model FootballPick {
  id              String   @id @default(cuid())
  matchId         String
  match           FootballMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  
  market          String
  selection       String
  description     String
  
  odds            Float
  trueOdds        Float
  estimatedProb   Float
  expectedValue   Float
  
  confidenceScore Int
  valueLabel      String   @default("MEDIUM")
  isPremiumPick   Boolean  @default(false)
  
  explanation     String
  status          String   @default("PENDING")
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model DailySyncLog {
  id              String   @id @default(cuid())
  syncedAt        DateTime @default(now())
  status          String
  sport           String   @default("TENNIS")
  matchesFound    Int      @default(0)
  picksGenerated  Int      @default(0)
  premiumPicks    Int      @default(0)
  circuits        String?
  errorMessage    String?
  durationMs      Int?
}

model UserPreferences {
  id              String   @id @default(cuid())
  userId          String?  @unique
  user            User?    @relation(fields: [userId], references: [id])

  showTennis      Boolean  @default(true)
  showFootball    Boolean  @default(true)
  showATP         Boolean  @default(true)
  showWTA         Boolean  @default(true)
  showChallenger  Boolean  @default(true)
  showITF         Boolean  @default(false)
  
  riskProfile     String   @default("BALANCED")
  minConfidence   Int      @default(60)
  minOdds         Float    @default(1.50)
  maxOdds         Float    @default(5.00)
  minEV           Float    @default(0.03)
  
  emailAlerts     Boolean  @default(false)
  telegramAlerts  Boolean  @default(false)
  pushAlerts      Boolean  @default(false)
  alertEmail      String?
  alertTelegram   String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
